        </mxCell>
        <mxCell id="st-cancel" value="cancelled&#xa;(terminal)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontStyle=1" vertex="1" parent="1">
