        <mxCell id="st-e6" value="POST /cancel&#xa;(CANCELLABLE)" style="endArrow=block;strokeColor=#dc2626;fontSize=10" edge="1" parent="1" source="st-search" target="st-cancel">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1065" y="280"/><mxPoint x="955" y="280"/></Array></mxGeometry>
