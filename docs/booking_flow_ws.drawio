        <mxCell id="state-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="800" y="80" width="760" height="420" as="geometry"/>
        </mxCell>
        <mxCell id="state-title" value="Ride status lifecycle (VALID_TRANSITIONS)" style="text;html=1;strokeColor=none;fillColor=none;fontStyle=1;fontSize=14;fontColor=#166534" vertex="1" parent="1">
          <mxGeometry x="820" y="90" width="400" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="st-req" value="requested" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#16a34a" vertex="1" parent="1">
          <mxGeometry x="840" y="150" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st-search" value="searching_driver" style="ellipse;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#16a34a;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1000" y="150" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st-assign" value="driver_assigned&#xa;(+ driver in WS)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#16a34a" vertex="1" parent="1">
          <mxGeometry x="1180" y="150" width="130" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="st-arrive" value="driver_arrived" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#16a34a" vertex="1" parent="1">
          <mxGeometry x="1360" y="150" width="110" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st-progress" value="in_progress" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#16a34a" vertex="1" parent="1">
          <mxGeometry x="1360" y="260" width="110" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st-done" value="completed&#xa;(terminal)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontStyle=1" vertex="1" parent="1">
