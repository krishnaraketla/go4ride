        <mxCell id="mock-note" value="Dev: mock_driver_enabled schedules automatic transitions&#xa;(assign → arrived → in_progress → completed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#f59e0b;align=left;spacingLeft=8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="820" y="430" width="400" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ws-events" value="Each transition emits a WebSocket event via Redis.&#xa;driver object included for: driver_assigned, driver_arrived, in_progress, completed&#xa;(and cancelled if driver was already assigned)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;align=left;spacingLeft=10;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="500" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="example-events" value="Example WS payloads (see docs/booking_flow_api.csv):&#xa;• connected: { type, ride_id, user_id }&#xa;• searching_driver: { ride_id, status, message, created_at }&#xa;• driver_assigned: above + driver { id, name, phone, vehicle_*, lat, lng, eta_min }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;align=left;spacingLeft=10;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="560" y="540" width="520" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="multi-instance" value="Multi-instance deploy: all API replicas subscribe to the same Redis channel, so WS clients on any instance receive events." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#3b82f6;align=left;spacingLeft=10;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1100" y="540" width="460" height="60" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
