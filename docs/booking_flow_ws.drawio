        </mxCell>
        <mxCell id="ec5" style="endArrow=block;strokeWidth=2;strokeColor=#7c3aed;dashed=1" edge="1" parent="1" source="ws-conn" target="redis">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
