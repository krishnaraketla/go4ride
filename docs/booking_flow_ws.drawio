          <mxGeometry x="200" y="170" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ws-auth" value="1. verify_token (access)&#xa;2. rider_owns_ride&#xa;3. websocket.accept()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7c3aed;align=left;spacingLeft=8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="460" y="160" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ws-conn" value="_connections[ride_id] += WebSocket&#xa;_subscribe_redis(ride_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7c3aed;align=left;spacingLeft=8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="200" y="270" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="redis" value="Redis&#xa;PUB/SUB&#xa;channel: ride:{ride_id}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fef3c7;strokeColor=#d97706;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="520" y="250" width="120" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="ride-svc-pub" value="ride_service._record_status()&#xa;→ publish_ride_event()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d97706;align=left;spacingLeft=8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="200" y="360" width="240" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ws-push" value="Listener: pubsub message →&#xa;ws.send_text(JSON) to all subscribers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7c3aed;align=left;spacingLeft=8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="480" y="360" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="keepalive" value="Client may send text/ping; server loops receive_text() until disconnect" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#64748b;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="450" width="400" height="30" as="geometry"/>
