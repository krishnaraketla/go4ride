          <mxGeometry x="1300" y="50" width="170" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="s1" value="geo_service: route + reverse geocode&#xa;fare_service: all ride types + fares&#xa;supply_service: drivers_nearby, pickup ETA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d97706;align=left;spacingLeft=8;fontSize=11" vertex="1" parent="lane-svc">
          <mxGeometry x="280" y="45" width="320" height="70" as="geometry"/>
        </mxCell>
