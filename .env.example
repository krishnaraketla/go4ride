DATABASE_URL=postgresql+asyncpg://go4ride:go4ride@localhost:5433/go4ride
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
OTP_PROVIDER=console
OTP_EXPIRE_MINUTES=10
OTP_DEBUG=true
MAPS_PROVIDER=mock
# Set MAPS_PROVIDER=google and MAPS_API_KEY for real geocoding, directions, and live ETA.
# Enable in GCP: Geocoding API, Directions API, Distance Matrix API.
MAPS_API_KEY=
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
APP_ENV=development
SQLALCHEMY_ECHO=false
MOCK_DRIVER_ENABLED=false
MOCK_DRIVER_AUTO_ADVANCE=true
MOCK_DRIVER_ASSIGN_DELAY_SEC=2
MOCK_DRIVER_STEP_DELAY_SEC=5
MOCK_DRIVER_ETA_MIN=5
DRIVER_SEARCH_DEFAULT_RADIUS_KM=5
DRIVER_SEARCH_MAX_RADIUS_KM=50
DRIVER_ETA_CACHE_TTL_SEC=30
DRIVER_LOCATION_PUBLISH_INTERVAL_SEC=10
DEFAULT_CURRENCY=INR
EMAIL_VERIFY_BONUS=5.00
REFERRAL_BONUS=5.00
MAX_SAVED_ADDRESSES_PER_USER=10
ADMIN_API_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=go4ride-kyc
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
