DATABASE_URL=postgresql+asyncpg://go4ride:go4ride@localhost:5433/go4ride
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
OTP_PROVIDER=console
OTP_EXPIRE_MINUTES=10
OTP_DEBUG=true
# Fixed OTP for pre-seeded test phones (no SMS). Set OTP_DEBUG=false in production.
OTP_BYPASS_CODE=123456
OTP_BYPASS_PHONES=+15555551001,+15555551002,+15555552001,+15555552002
# Pre-seeded riders/drivers (JSON). Phones should match OTP_BYPASS_PHONES.
SEED_TEST_USERS=[{"phone":"+15555551001","name":"Test Rider 1","role":"rider"},{"phone":"+15555551002","name":"Test Rider 2","role":"rider"},{"phone":"+15555552001","name":"Test Driver 1","role":"driver"},{"phone":"+15555552002","name":"Test Driver 2","role":"driver"}]
MAPS_PROVIDER=mock
# Set MAPS_PROVIDER=google and MAPS_API_KEY for real geocoding, routes, and live ETA.
# Enable in GCP: Geocoding API, Routes API.
MAPS_API_KEY=
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
APP_ENV=development
LOG_LEVEL=DEBUG
LOG_FORMAT=text
DB_SLOW_QUERY_MS=500
SQLALCHEMY_ECHO=false
MOCK_DRIVER_ENABLED=false
MOCK_DRIVER_AUTO_ADVANCE=true
MOCK_DRIVER_ASSIGN_DELAY_SEC=2
MOCK_DRIVER_STEP_DELAY_SEC=5
MOCK_DRIVER_ETA_MIN=5
DRIVER_SEARCH_DEFAULT_RADIUS_KM=5
DRIVER_SEARCH_MAX_RADIUS_KM=50
DRIVER_ETA_CACHE_TTL_SEC=30
DRIVER_LOCATION_PUBLISH_INTERVAL_SEC=10
# Set true only when running multiple app instances that must share WebSocket fan-out.
WEBSOCKET_REDIS_FANOUT=false
DEFAULT_CURRENCY=USD
EMAIL_VERIFY_BONUS=5.00
REFERRAL_BONUS=5.00
MAX_SAVED_ADDRESSES_PER_USER=10
ADMIN_API_KEY=
CLEAR_RIDES_ON_STARTUP=false
# Set true on Render to delete all rides on every deploy (demo/staging only).
AWS_REGION=ap-south-1
S3_BUCKET=go4ride-kyc
MAX_UPLOAD_SIZE_MB=10
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
